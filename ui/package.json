{
  "name": "photoview-ui",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkovaletp/photoview.git",
    "directory": "ui"
  },
  "license": "GPL-3.0",
  "description": "UI app for Photoview",
  "scripts": {
    "start": "vite --host=0.0.0.0",
    "mon": "nodemon",
    "build": "vite build",
    "build:dev": "NODE_ENV=development vite build --mode development --sourcemap --minify=false",
    "lint": "eslint ./src --max-warnings 0",
    "lint:ci": "eslint ./src --no-color --fix-dry-run | tee eslint-report.txt; eslint ./src --no-color --format json > eslint-report.json",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write *.{ts,tsx,js,json,css,md,graphql}",
    "test": "vitest",
    "test:ci": "CI=true vitest --run --coverage",
    "genSchemaTypes": "find src -type f -path '*/__generated__/*.ts' -delete && graphql-codegen --config codegen.ts && prettier --write \"src/**/__generated__/*.ts\"",
    "validateGQL": "graphql-inspector validate 'src/**/*.{ts,tsx}' '../api/graphql/resolvers/*.graphql' --deprecated",
    "extractTranslations": "i18next-cli extract && i18next-cli types",
    "extractTranslations:ci": "i18next-cli extract --ci --quiet && i18next-cli types --ci --quiet",
    "lintTranslations": "i18next-cli lint"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "dependencies": {
    "@apollo/client": "~3.14.0",
    "@dr.pogodin/react-helmet": "^3.2.2",
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/vite": "^4.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/js-cookie": "^3.0.6",
    "@types/luxon": "^3.7.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "blurhash": "^2.0.5",
    "clsx": "^2.1.1",
    "connect-history-api-fallback": "^2.0.0",
    "copy-to-clipboard": "^4.0.2",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.11",
    "graphql-ws": "^6.0.8",
    "i18next": "26.3.4",
    "js-cookie": "^3.0.8",
    "luxon": "^3.7.2",
    "mapbox-gl": "~3.25.0",
    "marked": "^18.0.5",
    "react": "19.2.7",
    "react-blurhash": "^0.3.0",
    "react-datepicker": "^9.0.0",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "17.0.8",
    "react-router-dom": "^7.18.1",
    "react-swipeable": "^7.0.2",
    "react-test-renderer": "19.2.7",
    "styled-components": "^6.4.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "url-join": "^5.0.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.21.0",
    "vite-plugin-svgr": "^5.2.0",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-codegen/near-operation-file-preset": "^5.0.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-inspector/cli": "^6.0.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitest/coverage-v8": "^3.2.7",
    "@vitest/ui": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "i18next-cli": "^1.65.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "browserslist": {
    "production": [
      "defaults",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true,
    "core-js": false,
    "core-js-pure": false,
    "yarn": false,
    "@swc/core@1.15.41": true
  }
}
